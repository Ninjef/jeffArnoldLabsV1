---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog — Jeff Arnold Labs" description="Technical writing by Jeff Arnold.">
  <h1 class="text-2xl font-semibold">Blog</h1>
  <ul class="mt-6 space-y-4">
    {posts.map((post) => (
      <li>
        <a href={`/blogs/${post.slug}`} class="text-lg underline">{post.data.title}</a>
        <div class="text-sm text-slate-500">
          {post.data.pubDate.toISOString().slice(0, 10)} · {post.data.description}
        </div>
      </li>
    ))}
  </ul>
</Layout>
