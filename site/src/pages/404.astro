---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page not found — Jeff Arnold Labs"
  description="The page you were looking for doesn't exist."
>
  <h1 class="text-3xl font-semibold">Page not found</h1>
  <p class="mt-4 text-slate-700">
    That URL doesn't match anything on this site. It may have moved, or never existed.
  </p>
  <ul class="mt-6 space-y-2 text-slate-700">
    <li>
      <a class="underline" href="/">Home</a>
    </li>
    <li>
      <a class="underline" href="/blogs">Blog</a>
    </li>
    <li>
      <a class="underline" href="/demos">Demos</a>
    </li>
  </ul>
</Layout>
